# 虚拟环境
.venv/
venv/
env/

# PyInstaller 构建临时目录（注意：不忽略 .exe 本身）
build/
build_temp/
dist/
*.spec

# 运行时临时文件（用户上传的小说临时副本）
temp/

# 敏感配置（包含 API Key）
.env

# Python 缓存
__pycache__/
*.pyc
*.pyo

# IDE / 编辑器
.vscode/
.idea/
*.swp
*.swo

# 操作系统元数据
.DS_Store
Thumbs.db

# 日志文件
*.log

# 测试小说文件（避免误传）
novel.txt
novel.docx
novel.pdf
novel.epub
test_*.txt